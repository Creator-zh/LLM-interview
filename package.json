{
  "name": "pyre-code",
  "version": "1.0.0",
  "description": "LeetCode-style ML coding problems — implement PyTorch modules from scratch",
  "license": "MIT",
  "author": "kiren",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiren/pyre"
  },
  "scripts": {
    "postinstall": "cd web && npm ci",
    "build:solutions": ".venv/bin/python scripts/build_solutions.py",
    "predev": "node scripts/check-python-env.js",
    "dev": "node scripts/dev-runner.js",
    "dev:backend": "node scripts/dev-runner.js --backend-only",
    "dev:frontend": "cd web && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
